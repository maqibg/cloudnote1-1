{
  "name": "cloudnote1-1",
  "version": "1.0.0",
  "description": "A cloud note-taking app built on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy && npm run db:init",
    "db:init": "wrangler d1 execute DB --file=./schema.sql --remote",
    "generate-types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run generate-types && tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.5.0",
    "jose": "^5.9.0",
    "quill": "^1.3.7",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=18"
  },
  "cloudflare": {
    "bindings": {
      "ADMIN_USERNAME": {
        "description": "管理员用户名（默认: admin）"
      },
      "ADMIN_PASSWORD": {
        "description": "管理员密码（必须设置强密码）"
      },
      "JWT_SECRET": {
        "description": "JWT 签名密钥（可使用命令生成: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"）"
      }
    }
  }
}
